{
  "name": "community-fe",
  "version": "1.0.0",
  "description": "PULSE React SPA",
  "type": "module",
  "dependencies": {
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.2",
    "jsdom": "^29.1.1",
    "mini-css-extract-plugin": "^2.9.4",
    "prettier": "^3.9.5",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
  },
  "scripts": {
    "build:react": "webpack --mode production",
    "build:watch": "webpack --mode development --watch",
    "format:check": "prettier --check index.html 'src/**/*.{js,jsx,css}' 'tests/**/*.js' 'docs/**/*.md' package.json playwright.config.js vitest.config.js webpack.config.js",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ui": "playwright test",
    "test:e2e:backend": "playwright test --config playwright.backend.config.js",
    "test:all": "npm run format:check && npm run build:react && npm run test:unit && npm run test:integration && npm run test:ui",
    "serve:test": "webpack serve --mode development"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/100-hours-a-week/KTB4-ian-community-FE.git"
  },
  "license": "ISC"
}
